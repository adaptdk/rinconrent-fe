{
  "kind": "collectionType",
  "collectionName": "investor_guides",
  "info": {
    "singularName": "investor-guide",
    "pluralName": "investor-guides",
    "displayName": "Investor Guide",
    "description": ""
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {
    "i18n": {
      "localized": true
    }
  },
  "attributes": {
    "title": {
      "type": "string",
      "pluginOptions": {
        "i18n": { "localized": true }
      }
    },
    "description": {
      "type": "text",
      "pluginOptions": {
        "i18n": { "localized": true }
      }
    },
    "slug": {
      "type": "uid",
      "targetField": "title",
      "pluginOptions": {
        "i18n": { "localized": true }
      }
    },
    "content": {
      "type": "richtext",
      "pluginOptions": {
        "i18n": { "localized": true }
      }
    },
    "category": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::investor-guide-category.investor-guide-category"
    },
    "featuredImage": {
      "type": "media",
      "multiple": false,
      "required": false,
      "allowedTypes": ["images"]
    },
    "blocks": {
      "type": "dynamiczone",
      "components": [
        "blocks.markdown",
        "blocks.faqs",
        "blocks.heading-section"
      ]
    }
  }
}
