{
  "kind": "collectionType",
  "collectionName": "properties",
  "info": {
    "singularName": "property",
    "pluralName": "properties",
    "displayName": "Property",
    "description": "Vacation rental property synced from Guesty PMS."
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {
    "i18n": {
      "localized": true
    }
  },
  "attributes": {
    "guestyId": {
      "type": "string",
      "required": true,
      "unique": true
    },
    "title": {
      "type": "string",
      "required": true,
      "pluginOptions": {
        "i18n": { "localized": true }
      }
    },
    "slug": {
      "type": "uid",
      "targetField": "title",
      "pluginOptions": {
        "i18n": { "localized": true }
      }
    },
    "propertyType": {
      "type": "string"
    },
    "accommodates": {
      "type": "integer"
    },
    "bedrooms": {
      "type": "integer"
    },
    "bathrooms": {
      "type": "decimal"
    },
    "summary": {
      "type": "text",
      "pluginOptions": {
        "i18n": { "localized": true }
      }
    },
    "description": {
      "type": "richtext",
      "pluginOptions": {
        "i18n": { "localized": true }
      }
    },
    "minNights": {
      "type": "integer"
    },
    "maxNights": {
      "type": "integer"
    },
    "checkInTime": {
      "type": "string"
    },
    "checkOutTime": {
      "type": "string"
    },
    "timezone": {
      "type": "string"
    },
    "address": {
      "type": "component",
      "repeatable": false,
      "component": "property.address"
    },
    "pricing": {
      "type": "component",
      "repeatable": false,
      "component": "property.pricing"
    },
    "amenities": {
      "type": "component",
      "repeatable": true,
      "component": "property.amenity",
      "pluginOptions": {
        "i18n": { "localized": true }
      }
    },
    "tags": {
      "type": "json"
    },
    "images": {
      "type": "media",
      "multiple": true,
      "required": false,
      "allowedTypes": ["images"]
    },
    "lastSyncedAt": {
      "type": "datetime"
    }
  }
}
