---
import StrapiImage from "./StrapiImage.astro";

interface Category {
  title: string;
  slug: string;
}

interface Props {
  title: string;
  slug: string;
  href: string;
  description?: string | null;
  publishedAt?: string | null;
  featuredImage?: { url: string; alternativeText?: string | null } | null;
  category?: Category | null;
  /** Base path used to build category filter URL (e.g. "travel-guide") */
  basePath: string;
}

const { title, href, description, publishedAt, featuredImage, category, basePath } = Astro.props;

const dateLabel = publishedAt
  ? new Date(publishedAt).toLocaleDateString("en-GB", {
      year: "numeric",
      month: "long",
      day: "numeric",
    })
  : null;
---

<div class="flex flex-col group h-full text-left">

  <!-- Image -->
  <a href={href}
    class="relative block w-full mb-5 overflow-hidden rounded-md bg-sand-alt shadow-sm"
    style="padding-bottom: 75%;">

    {featuredImage?.url ? (
      <StrapiImage
        src={featuredImage.url}
        alt={featuredImage.alternativeText || title}
        width={800}
        height={600}
        class="absolute inset-0 w-full h-full object-cover transition-transform duration-500 group-hover:scale-110"
      />
    ) : (
      <div class="absolute inset-0 flex items-center justify-center">
        <!-- Camera placeholder icon -->
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor"
          class="w-10 h-10 text-beige" aria-hidden="true">
          <path d="M12 9a3.75 3.75 0 1 0 0 7.5A3.75 3.75 0 0 0 12 9Z" />
          <path fill-rule="evenodd" d="M9.344 3.071a49.52 49.52 0 0 1 5.312 0c.967.052 1.83.585 2.332 1.39l.821 1.317c.24.383.645.643 1.11.71.386.054.77.113 1.152.177 1.432.239 2.429 1.493 2.429 2.909V18a3 3 0 0 1-3 3h-15a3 3 0 0 1-3-3V9.574c0-1.416.997-2.67 2.429-2.909.382-.064.766-.123 1.151-.178a1.56 1.56 0 0 0 1.11-.71l.822-1.315a2.942 2.942 0 0 1 2.332-1.39ZM6.75 12.75a5.25 5.25 0 1 1 10.5 0 5.25 5.25 0 0 1-10.5 0Zm12-1.5a.75.75 0 1 0 0-1.5.75.75 0 0 0 0 1.5Z" clip-rule="evenodd" />
        </svg>
      </div>
    )}
  </a>

  <!-- Category pill -->
  {category && (
    <div class="flex flex-wrap gap-2 mb-3">
      <a
        href={`/${basePath}/category/${category.slug}`}
        class="bg-beige text-dark-blue text-body-xs uppercase px-3 py-1 rounded-full font-bold"
      >
        {category.title}
      </a>
    </div>
  )}

  <!-- Body -->
  <div class="flex flex-col flex-1">
    <h2 class="font-heading font-bold text-h5 text-secondary group-hover:text-primary-600 transition-colors duration-300 leading-tight mb-3">
      <a href={href}>{title}</a>
    </h2>

    {description && (
      <p class="line-clamp-3 mb-4 leading-relaxed text-muted">
        {description}
      </p>
    )}

    {dateLabel && (
      <div class="mt-auto text-body-xs font-bold text-grey-disabled pt-2">
        {dateLabel}
      </div>
    )}
  </div>

</div>
