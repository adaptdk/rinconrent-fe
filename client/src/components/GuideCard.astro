---
import StrapiImage from "./StrapiImage.astro";

interface Category {
  title: string;
  slug: string;
}

interface Props {
  title: string;
  slug: string;
  href: string;
  description?: string | null;
  publishedAt?: string | null;
  featuredImage?: { url: string; alternativeText?: string | null } | null;
  category?: Category | null;
  /** Base path used to build category filter URL (e.g. "travel-guide") */
  basePath: string;
  /**
   * Layout variant. Below lg: every variant renders as the default vertical card.
   * - "default"      vertical card (image on top)
   * - "lg-featured"  vertical card with larger title + more description lines at lg:
   * - "lg-compact"   horizontal card (image left, content right) at lg:
   */
  variant?: "default" | "lg-featured" | "lg-compact";
}

const { title, href, description, publishedAt, featuredImage, category, basePath, variant = "default" } = Astro.props;

const dateLabel = publishedAt
  ? new Date(publishedAt).toLocaleDateString("en-GB", {
      year: "numeric",
      month: "long",
      day: "numeric",
    })
  : null;
---

<div class:list={["flex flex-col group h-full text-left", variant === "lg-compact" && "lg:flex-row lg:gap-6"]}>

  <!-- Image -->
  <a href={href}
    class:list={[
      "relative block w-full aspect-[4/3] mb-5 overflow-hidden rounded-md bg-sand-alt shadow-sm",
      variant === "lg-featured" && "lg:aspect-[16/9]",
      variant === "lg-compact" && "lg:w-2/5 lg:shrink-0 lg:mb-0 lg:aspect-auto lg:self-stretch",
    ]}>

    {featuredImage?.url ? (
      <StrapiImage
        src={featuredImage.url}
        alt={featuredImage.alternativeText || title}
        width={800}
        height={600}
        class="absolute inset-0 w-full h-full object-cover transition-transform duration-500 group-hover:scale-110"
      />
    ) : (
      <div class="absolute inset-0 flex items-center justify-center">
        <!-- Camera placeholder icon -->
        <i class="fa-solid fa-camera fa-3x text-beige" aria-hidden="true"></i>
      </div>
    )}
  </a>

  <!-- Body -->
  <div class="flex flex-col flex-1">
    {category && (
      <div class="flex flex-wrap gap-2 mb-3">
        <a
          href={`/${basePath}/category/${category.slug}`}
          class="bg-beige text-dark-blue text-body-xs uppercase px-3 py-1 rounded-full font-bold"
        >
          {category.title}
        </a>
      </div>
    )}

    <h2 class:list={[
      "font-heading font-bold text-h5 text-secondary group-hover:text-primary-600 transition-colors duration-300 leading-tight mb-3",
      variant === "lg-featured" && "lg:text-h3",
    ]}>
      <a href={href}>{title}</a>
    </h2>

    {description && (
      <p class:list={[
        "line-clamp-3 mb-4 leading-relaxed text-muted",
        variant === "lg-featured" && "lg:line-clamp-4",
      ]}>
        {description}
      </p>
    )}

    {dateLabel && (
      <div class="mt-auto text-body-xs font-bold text-grey-disabled pt-2">
        {dateLabel}
      </div>
    )}
  </div>

</div>
