---
const languages = [
  { code: "en", label: "English", flag: "🇬🇧", href: "/" },
  { code: "da", label: "Dansk",   flag: "🇩🇰", href: "/da/" },
  { code: "es", label: "Español", flag: "🇪🇸", href: "/es/" },
];

const currentLang = "en";
const current = languages.find(l => l.code === currentLang)!;
const others = languages.filter(l => l.code !== currentLang);
---

<div class="relative group">
  <button
    class="flex items-center gap-2 text-sand-white text-body-s py-0.5 hover:opacity-75 transition-opacity duration-200"
    aria-expanded="false"
    aria-haspopup="listbox"
    aria-label="Select language"
    data-lang-toggle
  >
    <span aria-hidden="true">{current.flag}</span>
    <span>{current.label}</span>
    <i class="fa-solid fa-chevron-down fa-xs inline-block shrink-0 transition-transform duration-200" aria-hidden="true"></i>
  </button>

  {/* Visibility via CSS only — no `hidden` class (see _header.css) */}
  <ul
    class="header__dropdown min-w-[150px]"
    role="listbox"
    aria-label="Select language"
  >
    {others.map(lang => (
      <li role="option" aria-selected="false">
        <a
          href={lang.href}
          class="flex items-center gap-2 px-4 py-2.5 text-body-s text-dark-grey hover:bg-beige hover:text-dark-blue transition-colors duration-200 focus-visible:outline-2 focus-visible:outline-dark-blue"
          hreflang={lang.code}
        >
          <span aria-hidden="true">{lang.flag}</span>
          <span>{lang.label}</span>
        </a>
      </li>
    ))}
  </ul>
</div>

<script>
  import "../scripts/lang-picker";
</script>
