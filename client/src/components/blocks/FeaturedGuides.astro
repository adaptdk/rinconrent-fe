---
import type { FeaturedGuidesProps, GuideCardData } from "../../utils/types";
import { getLatestGuides } from "../../utils/loaders";
import GuideCard from "../GuideCard.astro";

interface Props {
  data: FeaturedGuidesProps;
}

const {
  data: {
    title,
    subtitle,
    readMoreLink,
    showPosts,
    selectedTravelGuides = [],
    selectedInvestorGuides = [],
  },
} = Astro.props;

let guides: GuideCardData[] = [];

if (showPosts === "selected") {
  const combined: GuideCardData[] = [
    ...(selectedTravelGuides ?? []).map((g) => ({
      title: g.title,
      slug: g.slug,
      href: `/travel-guide/${g.slug}`,
      description: g.description,
      publishedAt: g.publishedAt,
      featuredImage: g.featuredImage,
      category: g.category,
      basePath: "travel-guide" as const,
    })),
    ...(selectedInvestorGuides ?? []).map((g) => ({
      title: g.title,
      slug: g.slug,
      href: `/investor-guide/${g.slug}`,
      description: g.description,
      publishedAt: g.publishedAt,
      featuredImage: g.featuredImage,
      category: g.category,
      basePath: "investor-guide" as const,
    })),
  ];
  combined.sort(
    (a, b) =>
      (b.publishedAt ? new Date(b.publishedAt).getTime() : 0) -
      (a.publishedAt ? new Date(a.publishedAt).getTime() : 0)
  );
  guides = combined.slice(0, 3);
} else if (showPosts) {
  const fetched = await getLatestGuides(showPosts);
  guides = fetched.map((g) => {
    const basePath = g._source === "travel" ? "travel-guide" : "investor-guide";
    return {
      title: g.title,
      slug: g.slug,
      href: `/${basePath}/${g.slug}`,
      description: g.description,
      publishedAt: g.publishedAt,
      featuredImage: g.featuredImage,
      category: g.category,
      basePath,
    };
  });
}
---

<section>
  <div class="container py-16">
    {(title || subtitle) && (
      <div class="mb-10 text-center">
        {title && (
          <h2 class="font-heading font-bold text-h2 text-secondary leading-tight mb-4">
            {title}
          </h2>
        )}
        {subtitle && (
          <p class="text-muted leading-relaxed max-w-2xl mx-auto">{subtitle}</p>
        )}
      </div>
    )}

    {guides.length > 0 && (
      <div class="grid gap-8 lg:grid-cols-2 lg:gap-10">
        {guides[0] && <GuideCard {...guides[0]} variant="lg-featured" />}
        {(guides[1] || guides[2]) && (
          <div class="grid gap-8 lg:flex lg:flex-col">
            {guides[1] && <GuideCard {...guides[1]} variant="lg-compact" />}
            {guides[2] && <GuideCard {...guides[2]} variant="lg-compact" />}
          </div>
        )}
      </div>
    )}

    {readMoreLink?.href && (
      <div class="mt-10 text-center">
        <a
          href={readMoreLink.href}
          target={readMoreLink.isExternal ? "_blank" : undefined}
          rel={readMoreLink.isExternal ? "noopener noreferrer" : undefined}
          class:list={[
            "button",
            readMoreLink.type === "SECONDARY" ? "button-secondary" : "button-primary",
          ]}
        >
          {readMoreLink.label}
        </a>
      </div>
    )}
  </div>
</section>
