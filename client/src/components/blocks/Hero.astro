---
import type { HeroProps } from "../../utils/types";
import StrapiImage from "../StrapiImage.astro";

interface Props {
  data: HeroProps;
}

const {
  data: { heading, text, mediaType, image, video, textDark, links },
} = Astro.props;

const BASE_URL = (
  import.meta.env.STRAPI_BASE_URL ?? "http://localhost:1337"
).replace(/\/api$/, "");

function getStrapiUrl(url: string | null | undefined): string | undefined {
  if (!url) return undefined;
  if (url.startsWith("data:") || url.startsWith("http") || url.startsWith("//"))
    return url;
  return `${BASE_URL}${url}`;
}

const isVideo = (mediaType ?? "image") === "video" && !!video?.url;
const textColorClass = textDark ? "text-secondary" : "text-white";
const videoPoster = image?.url ? getStrapiUrl(image.url) : undefined;
---

<section
  class="relative h-[80vh] min-h-[500px] overflow-hidden"
  aria-label={heading}
>
  {
    isVideo && (
      <video
        class="absolute inset-0 h-full w-full object-cover"
        autoplay={true}
        loop={true}
        muted={true}
        playsinline={true}
        poster={videoPoster}
        aria-hidden="true"
      >
        <source
          src={getStrapiUrl(video!.url)}
          type={video!.mime ?? "video/mp4"}
        />
      </video>
    )
  }
  {
    !isVideo && image?.url && (
      <StrapiImage
        src={image.url}
        alt=""
        width={1920}
        height={1080}
        class="absolute inset-0 h-full w-full object-cover object-center"
      />
    )
  }

  <div class="absolute inset-0 bg-black/40" aria-hidden="true"></div>

  <div class={`absolute inset-0 z-10 flex items-center ${textColorClass}`}>
    <div class="container mx-auto px-6 md:px-12">
      <div class="max-w-[700px]">
        <h1
          class={`font-heading font-bold text-3xl md:text-5xl xl:text-6xl leading-tight ${textColorClass}`}
        >
          {heading}
        </h1>
        {
          text && (
            <p class="mt-6 text-lg md:text-xl font-normal leading-relaxed">
              {text}
            </p>
          )
        }
        {
          links && links.length > 0 && (
            <div class="mt-8 flex flex-wrap gap-4">
              {links.map((link) => (
                <a
                  class={`button ${link.type === "SECONDARY" ? "button-secondary" : "button-primary"}`}
                  href={link.href}
                  target={link.isExternal ? "_blank" : "_self"}
                  rel={link.isExternal ? "noopener noreferrer" : undefined}
                >
                  {link.label}
                </a>
              ))}
            </div>
          )
        }
      </div>
    </div>
  </div>
</section>
