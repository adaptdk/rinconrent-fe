---
import type { TestimonialsProps } from "../../utils/types";

interface Props {
  data: TestimonialsProps;
}

const {
  data: { title, content, testimonials = [] },
} = Astro.props;
---

<section class="bg-gray-blue py-16">
  <div class="mx-auto container px-6">
    {
      title && (
        <h2 class="text-h2 font-bold font-heading text-white mb-4 leading-tight">
          {title}
        </h2>
      )
    }
    {
      content && (
        <p class="text-body-l text-white/80 leading-relaxed mb-8">{content}</p>
      )
    }

    <div class="relative mt-8" data-testimonial-slider>
      <button
        class="absolute left-0 top-1/2 -translate-y-1/2 -translate-x-5 lg:-translate-x-10 z-10 w-11 h-11 rounded-full flex items-center justify-center bg-white/20 text-white border-0 cursor-pointer transition-colors hover:bg-primary-600 disabled:opacity-40 disabled:cursor-not-allowed"
        aria-label="Previous testimonials"
        data-testimonial-prev
      >
        <svg
          width="18"
          height="18"
          fill="none"
          stroke="currentColor"
          viewBox="0 0 24 24"
          aria-hidden="true"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M15 19l-7-7 7-7"></path>
        </svg>
      </button>

      <div class="overflow-hidden" data-testimonial-viewport>
        <div class="flex">
          {
            testimonials.map((testimonial) => (
              <div class="flex-none w-[85vw] sm:w-[45%] lg:w-[42%] mr-6">
                <div class="relative p-7 pl-16 bg-beige rounded-xl min-h-[220px] h-full flex flex-col">
                  <div class="absolute left-7 top-7">
                    <svg
                      width="22"
                      height="19"
                      viewBox="0 0 22 19"
                      fill="none"
                      xmlns="http://www.w3.org/2000/svg"
                      aria-hidden="true"
                    >
                      <path
                        d="M8.28467 17.8096C7.67399 18.1149 7.07422 18.2676 6.48535 18.2676C5.63477 18.2676 4.76237 18.0277 3.86816 17.5479C2.99577 17.068 2.25423 16.3156 1.64355 15.2905C1.03288 14.2655 0.727539 12.9896 0.727539 11.4629C0.727539 9.34733 1.39274 7.30811 2.72314 5.34521C4.07536 3.38232 6.64893 1.89925 10.4438 0.895996L11.1309 3.12061C9.12435 3.64404 7.63037 4.4401 6.64893 5.50879C5.68929 6.55566 5.20947 7.65706 5.20947 8.81299C5.20947 9.75081 5.56934 10.5687 6.28906 11.2666C7.00879 11.9645 7.9248 12.3135 9.03711 12.3135C9.25521 12.3135 9.58236 12.2917 10.0186 12.248C10.3239 13.055 10.4766 13.7311 10.4766 14.2764C10.4766 15.1051 10.2694 15.8249 9.85498 16.4355C9.44059 17.0244 8.91715 17.4824 8.28467 17.8096ZM18.5571 17.8096C17.9465 18.1149 17.3467 18.2676 16.7578 18.2676C15.9072 18.2676 15.0348 18.0277 14.1406 17.5479C13.2682 17.068 12.5267 16.3156 11.916 15.2905C11.3271 14.2655 11.0327 12.9896 11.0327 11.4629C11.0327 9.34733 11.6979 7.30811 13.0283 5.34521C14.3805 3.38232 16.9541 1.89925 20.749 0.895996L21.4688 3.12061C19.4622 3.64404 17.9683 4.4401 16.9868 5.50879C16.0272 6.55566 15.5474 7.65706 15.5474 8.81299C15.5474 9.77262 15.8963 10.6014 16.5942 11.2993C17.314 11.9754 18.23 12.3135 19.3423 12.3135C19.5386 12.3135 19.8548 12.2917 20.291 12.248C20.5964 13.055 20.749 13.7311 20.749 14.2764C20.749 15.1051 20.5418 15.8249 20.1274 16.4355C19.7131 17.0244 19.1896 17.4824 18.5571 17.8096Z"
                        fill="#746E66"
                      />
                    </svg>
                  </div>
                  <p class="text-dark-blue text-body-s leading-relaxed whitespace-pre-line flex-1">
                    {testimonial.content}
                  </p>
                  <p class="mt-4 font-bold text-dark-blue text-body-s">
                    {testimonial.author}
                  </p>
                </div>
              </div>
            ))
          }
        </div>
      </div>

      <button
        class="absolute right-0 top-1/2 -translate-y-1/2 translate-x-5 lg:translate-x-10 z-10 w-11 h-11 rounded-full flex items-center justify-center bg-white/20 text-white border-0 cursor-pointer transition-colors hover:bg-primary-600 disabled:opacity-40 disabled:cursor-not-allowed"
        aria-label="Next testimonials"
        data-testimonial-next
      >
        <svg
          width="18"
          height="18"
          fill="none"
          stroke="currentColor"
          viewBox="0 0 24 24"
          aria-hidden="true"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M9 5l7 7-7 7"></path>
        </svg>
      </button>

      <div class="mt-8 h-0.5 w-full bg-white/20 relative">
        <div
          class="absolute left-0 top-0 h-full bg-primary-600 transition-none"
          style="width: 0%"
          data-testimonial-progress
        >
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  import EmblaCarousel from "embla-carousel";

  document
    .querySelectorAll<HTMLElement>("[data-testimonial-slider]")
    .forEach((root) => {
      const viewport = root.querySelector<HTMLElement>(
        "[data-testimonial-viewport]",
      );
      if (!viewport) return;

      const embla = EmblaCarousel(viewport, {
        loop: true,
        align: "start",
        dragFree: false,
      });

      const prevBtn = root.querySelector<HTMLButtonElement>(
        "[data-testimonial-prev]",
      );
      const nextBtn = root.querySelector<HTMLButtonElement>(
        "[data-testimonial-next]",
      );
      const progressBar = root.querySelector<HTMLElement>(
        "[data-testimonial-progress]",
      );

      prevBtn?.addEventListener("click", () => embla.scrollPrev());
      nextBtn?.addEventListener("click", () => embla.scrollNext());

      const updateProgress = () => {
        if (!progressBar) return;
        const progress = Math.max(0, Math.min(1, embla.scrollProgress()));
        progressBar.style.width = `${progress * 100}%`;
      };

      embla.on("scroll", updateProgress);
      embla.on("init", updateProgress);
    });
</script>
