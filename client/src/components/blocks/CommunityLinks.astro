---
import type { CommunityLinksProps } from "../../utils/types";

interface Props {
  data: CommunityLinksProps;
}

const {
  data: { heading, link },
} = Astro.props;
---

<section class="bg-surface-alt">
  <div class="mx-auto max-w-4xl px-6 py-16">
    {heading && (
      <h2 class="text-center text-2xl font-bold text-secondary font-heading">
        {heading}
      </h2>
    )}
    {link && link.length > 0 && (
      <div class="mt-10 grid gap-6 sm:grid-cols-2">
        {link.map((item) => (
          <a
            href={item.href}
            target="_blank"
            rel="noopener noreferrer"
            class="group flex flex-col rounded-xl border border-border bg-surface-raised p-6 transition hover:shadow-lg hover:border-border-hover"
          >
            <h3 class="text-lg font-semibold text-secondary group-hover:text-primary-600 transition font-heading">
              {item.title}
            </h3>
            <p class="mt-2 text-sm text-muted leading-relaxed flex-1">
              {item.description}
            </p>
            <span class="mt-4 inline-flex items-center gap-1 text-sm font-medium text-primary-600">
              {item.label}
              <i class="fa-solid fa-arrow-up-right-from-square inline-block transition group-hover:translate-x-0.5" aria-hidden="true"></i>
            </span>
          </a>
        ))}
      </div>
    )}
  </div>
</section>
