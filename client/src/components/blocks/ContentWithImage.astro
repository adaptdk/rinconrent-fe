---
import type { ContentWithImageProps } from "../../utils/types";
import StrapiImage from "../StrapiImage.astro";

interface Props {
  data: ContentWithImageProps;
}

const {
  data: { heading, text, image, links, imagePosition: position },
} = Astro.props;

const headingId = `cwi-${heading
  .toLowerCase()
  .replace(/\s+/g, "-")
  .replace(/[^a-z0-9-]/g, "")
  .slice(0, 40)}`;
const isFullWidth = position === "full_width";
---

<section aria-labelledby={headingId}>
  <div class="mx-auto container px-6 py-20">
    {
      isFullWidth ? (
        <div class="flex flex-col gap-10">
          <div>
            <h2
              id={headingId}
              class="font-bold tracking-tight text-secondary font-heading"
            >
              {heading}
            </h2>
            <p class="mt-4 leading-relaxed text-muted max-w-2xl">{text}</p>
            {links && links.length > 0 && (
              <div class="mt-8 flex flex-wrap gap-3">
                {links.map((link) => (
                  <a
                    class={`button ${link.type === "SECONDARY" ? "button-secondary" : "button-primary"}`}
                    href={link.href}
                    target={link.isExternal ? "_blank" : "_self"}
                    rel={link.isExternal ? "noopener noreferrer" : undefined}
                  >
                    {link.label}
                  </a>
                ))}
              </div>
            )}
          </div>
          <StrapiImage
            src={image.url}
            alt={image.alternativeText}
            height={600}
            width={1200}
            class="w-full rounded-2xl object-cover shadow-sm"
          />
        </div>
      ) : (
        <div
          class={`flex flex-col items-center gap-10 lg:gap-16 ${position === "left" ? "lg:flex-row-reverse" : "lg:flex-row"}`}
        >
          <div class="w-full lg:w-1/2">
            <StrapiImage
              src={image.url}
              alt={image.alternativeText}
              height={600}
              width={800}
              class="w-full rounded-2xl object-cover shadow-sm"
            />
          </div>
          <div class="w-full lg:w-1/2">
            <h2
              id={headingId}
              class="font-bold tracking-tight text-secondary font-heading"
            >
              {heading}
            </h2>
            <p class="mt-4 leading-relaxed text-muted">{text}</p>
            {links && links.length > 0 && (
              <div class="mt-8 flex flex-wrap gap-3">
                {links.map((link) => (
                  <a
                    class={`button ${link.type === "SECONDARY" ? "button-secondary" : "button-primary"}`}
                    href={link.href}
                    target={link.isExternal ? "_blank" : "_self"}
                    rel={link.isExternal ? "noopener noreferrer" : undefined}
                  >
                    {link.label}
                  </a>
                ))}
              </div>
            )}
          </div>
        </div>
      )
    }
  </div>
</section>
