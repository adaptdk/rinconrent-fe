---
import type { FeaturedArticlesProps } from "../../utils/types";
import { formatDate } from "../../utils/index";
import StrapiImage from "../StrapiImage.astro";

interface Props {
  data: FeaturedArticlesProps;
}

const {
  data: { articles },
} = Astro.props;
---

<section>
  <div class="container py-16">
    <div class="space-y-8">
      {articles.map((article) => (
        <a
          href={`/blog/${article.slug}`}
          class="group flex flex-col gap-6 rounded-card border border-border bg-surface-raised p-4 transition hover:shadow-md hover:border-border-hover sm:flex-row sm:items-center"
        >
          <div class="shrink-0 sm:w-48">
            <StrapiImage
              src={article.featuredImage.url}
              alt={article.featuredImage.alternativeText}
              width={300}
              height={200}
              class="h-36 w-full rounded-lg object-cover sm:h-32"
            />
          </div>
          <div class="flex-1 min-w-0">
            <h3 class="text-lg font-semibold text-secondary group-hover:text-primary-700 transition font-heading">
              {article.title}
            </h3>
            <div class="mt-1 flex items-center gap-2 text-sm text-faint">
              <span class="font-medium text-primary-600">{article.author.fullName}</span>
              <span>&middot;</span>
              <time>{formatDate(article.publishedAt)}</time>
            </div>
            <p class="mt-2 text-sm leading-relaxed text-muted line-clamp-2">{article.description}</p>
          </div>
        </a>
      ))}
    </div>
  </div>
</section>
