---
import type { PersonCardProps } from "../../utils/types";
import StrapiImage from "../StrapiImage.astro";
interface Props {
  data: PersonCardProps;
}

const {
  data: { personName, personJob, image, text },
} = Astro.props;
---

<section>
  <div class="container py-16">
    <div class="flex flex-col items-center gap-8 rounded-2xl border border-border bg-surface-raised p-8 shadow-sm md:flex-row md:gap-10">
      {image && (
        <div class="w-full shrink-0 md:w-1/3">
          <StrapiImage
            src={image.url}
            alt={image.alternativeText}
            height={400}
            width={400}
            class="w-full rounded-xl object-cover aspect-square"
          />
        </div>
      )}
      <div>
        <blockquote class="text-lg leading-relaxed text-muted italic">"{text}"</blockquote>
        <div class="mt-6">
          <p class="font-semibold text-secondary font-heading">{personName}</p>
          <p class="text-sm text-faint">{personJob}</p>
        </div>
      </div>
    </div>
  </div>
</section>
