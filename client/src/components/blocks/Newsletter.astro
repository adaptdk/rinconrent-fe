---
import type { NewsletterProps } from "../../utils/types";

interface Props {
  data: NewsletterProps;
}

const {
  data: { heading, text, placeholder, label },
} = Astro.props;
---

<section>
  <div class="container py-20">
    <div class="rounded-2xl bg-primary-50 px-8 py-14 text-center sm:px-16">
      <h2 class="text-2xl font-bold tracking-tight text-secondary sm:text-3xl font-heading">{heading}</h2>
      <p class="mt-3 text-muted">{text}</p>
      <form class="mt-8 flex flex-col items-center gap-3 sm:flex-row sm:justify-center">
        <input
          class="w-full rounded-button border border-border bg-surface-raised px-4 py-2.5 text-sm text-secondary placeholder:text-faint focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-100 sm:w-72"
          type="email"
          placeholder={placeholder}
        />
        <button
          class="w-full rounded-button bg-primary-600 px-5 py-2.5 text-sm font-semibold text-white shadow-sm hover:bg-primary-700 transition sm:w-auto"
          type="submit"
        >
          {label}
        </button>
      </form>
    </div>
  </div>
</section>
