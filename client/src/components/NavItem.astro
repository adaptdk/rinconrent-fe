---
import type { NavItem } from "../utils/types";

interface Props {
  item: NavItem;
  currentPath: string;
  isBold?: boolean;
  mobileMode?: boolean;
}

const { item, currentPath, isBold = false, mobileMode = false } = Astro.props;

const hasChildren = item.children && item.children.length > 0;
const isActive = item.href ? currentPath === item.href : false;
const target = item.isExternal ? "_blank" : "_self";
const rel = item.isExternal ? "noopener noreferrer" : undefined;
const submenuId = item.label.toLowerCase().replace(/[^a-z0-9]+/g, "-");
---

{mobileMode ? (
  <div class="border-b border-grey-border last:border-0">
    {hasChildren ? (
      <button
        class:list={["w-full flex items-center justify-between py-2.5 text-dark-grey hover:text-dark-blue transition-colors duration-200", isBold && "font-bold"]}
        data-submenu-open={submenuId}
        aria-haspopup="true"
      >
        <span>{item.label}</span>
        <svg class="w-4 h-4 shrink-0 -rotate-90" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
        </svg>
      </button>
    ) : (
      <a
        href={item.href}
        class:list={[
          "block py-2.5 transition-colors duration-200",
          isBold && "font-bold",
          isActive ? "text-dark-blue font-semibold" : "text-dark-grey hover:text-dark-blue",
        ]}
        target={target}
        rel={rel}
      >
        {item.label}
      </a>
    )}
  </div>
) : (
  hasChildren ? (
    <div class="group relative">
      <button
        class:list={[
          "header__nav-link text-dark-grey hover:text-dark-blue transition-colors duration-200",
          isBold && "font-bold text-dark-blue",
        ]}
        aria-expanded="false"
        aria-haspopup="true"
        data-dropdown
      >
        {item.label}
        <svg class="w-3 h-3 shrink-0 transition-transform duration-200" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
        </svg>
      </button>

      <ul class="header__dropdown" role="menu">
        {item.children!.map(child => (
          <li role="none">
            <a
              href={child.href}
              class="block px-4 py-3 text-body-s text-dark-grey hover:bg-sand-alt hover:text-dark-blue transition-colors duration-200 whitespace-nowrap focus-visible:outline-2 focus-visible:outline-dark-blue focus-visible:outline-offset-[-2px]"
              role="menuitem"
              target={child.isExternal ? "_blank" : "_self"}
              rel={child.isExternal ? "noopener noreferrer" : undefined}
            >
              {child.label}
            </a>
          </li>
        ))}
      </ul>
    </div>
  ) : (
    <a
      href={item.href}
      class:list={[
        "header__nav-link text-dark-grey hover:text-dark-blue transition-colors duration-200",
        isBold && "font-bold text-dark-blue",
        isActive && "header__nav-link--active",
      ]}
      target={target}
      rel={rel}
    >
      {item.label}
    </a>
  )
)}
