---
interface Props {
  question: string;
  answer: string;
  hidden?: boolean;
}

const { question, answer, hidden = false } = Astro.props;
---

<div
  class:list={["faq-item w-full", { "faq-hidden": hidden }]}
  itemscope
  itemprop="mainEntity"
  itemtype="https://schema.org/Question"
>
  <details class="group border-b border-border bg-white duration-150">
    <summary class="block cursor-pointer text-secondary transition-colors duration-150 hover:text-dark-blue marker:hidden">
      <div class="flex flex-row items-center justify-between px-5 pt-4 pb-4">
        <p class="mb-0 flex-1 text-body-l font-body font-semibold leading-snug" itemprop="name">
          {question}
        </p>
        <span class="faq-arrow relative ml-4 inline-flex h-5 w-5 shrink-0 items-center justify-center transition-transform duration-200 group-open:rotate-180">
          <i class="fa-solid fa-chevron-down fa-sm" aria-hidden="true"></i>
        </span>
      </div>
    </summary>
    <div
      class="px-5 pb-4 text-left"
      itemscope
      itemprop="acceptedAnswer"
      itemtype="https://schema.org/Answer"
    >
      <div itemprop="text" class="prose prose-sm max-w-none text-muted" set:html={answer} />
    </div>
  </details>
</div>
