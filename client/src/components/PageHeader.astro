---
import type { PageHeaderProps } from "../utils/types";
import StrapiImage from "./StrapiImage.astro";

interface Props {
  data?: PageHeaderProps | null;
  fallbackTitle?: string | null;
}

const { data, fallbackTitle } = Astro.props;

if (!data || data.hideHeader) return;

const {
  headerType = "text",
  headerSize = "small",
  horizontalLayout = false,
  pretitle,
  subtitle,
  image,
  video,
} = data;

const title = data.title || fallbackTitle;

const isMediaType = headerType === "image" || headerType === "video";

const textPadding =
  headerSize === "small" ? "py-10 md:py-14" : "py-16 md:py-24";
const mediaHeight =
  headerSize === "small" ? "h-[40vh] min-h-[300px]" : "h-[60vh] min-h-[400px]";

const BASE_URL = import.meta.env.STRAPI_BASE_URL ?? "http://localhost:1337";

function getStrapiMedia(url: string | null | undefined): string | null {
  if (!url) return null;
  if (url.startsWith("data:") || url.startsWith("http") || url.startsWith("//"))
    return url;
  return `${BASE_URL}${url}`;
}

const videoSrc = video ? getStrapiMedia(video.url) : null;
---

{
  isMediaType ? (
    <section class={`relative w-full overflow-hidden ${mediaHeight}`}>
      {headerType === "image" && image ? (
        <StrapiImage
          src={image.url}
          alt={image.alternativeText}
          width={1920}
          height={1080}
          class="absolute inset-0 h-full w-full object-cover"
        />
      ) : headerType === "video" && videoSrc ? (
        <video
          class="absolute inset-0 h-full w-full object-cover"
          autoplay={true}
          muted={true}
          loop={true}
          playsinline={true}
        >
          <source src={videoSrc} type={video?.mime ?? "video/mp4"} />
        </video>
      ) : (
        <div class="absolute inset-0 bg-gradient-to-br from-stone-700 to-stone-900" />
      )}

      <div class="absolute inset-0 bg-black/40" />

      <div class="absolute bottom-0 left-0 right-0">
        <div class="container pb-10 md:pb-14">
          {pretitle && (
            <p class="mb-2 text-body-s font-semibold uppercase tracking-widest text-white/70">
              {pretitle}
            </p>
          )}
          {title && (
            <h1 class="font-heading text-h1 font-bold leading-tight text-white">
              {title}
            </h1>
          )}
          {subtitle && (
            <p class="mt-3 max-w-2xl text-body-l text-white/80">{subtitle}</p>
          )}
        </div>
      </div>
    </section>
  ) : (
    <section class={`bg-sand ${textPadding}`}>
      <div
        class={`container ${horizontalLayout ? "flex flex-col gap-8 md:flex-row md:items-start md:gap-16" : ""}`}
      >
        <div class={horizontalLayout ? "md:w-2/5" : ""}>
          {pretitle && (
            <p class="mb-3 text-body-s font-semibold uppercase tracking-widest text-primary-600">
              {pretitle}
            </p>
          )}
          {title && (
            <h1 class="font-heading text-h1 font-bold leading-tight text-secondary">
              {title}
            </h1>
          )}
          {!horizontalLayout && subtitle && (
            <p class="mt-4 max-w-2xl text-body-l text-muted">{subtitle}</p>
          )}
        </div>

        {horizontalLayout && subtitle && (
          <div class="md:w-3/5">
            <p class="text-body-l text-muted leading-relaxed">{subtitle}</p>
          </div>
        )}
      </div>
    </section>
  )
}
