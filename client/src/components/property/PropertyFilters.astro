---
import type { CountedOption } from "../../utils/property/filter-options";

interface Props {
  types: CountedOption[];
  categories: CountedOption[];
  features: CountedOption[];
  minPrice: number;
  maxPrice: number;
  currencySymbol: string;
}

const { types, categories, features, minPrice, maxPrice, currencySymbol } = Astro.props;

const BATHROOM_OPTIONS = [
  { value: "0", label: "Any" },
  { value: "1", label: "1" },
  { value: "2", label: "2" },
  { value: "3", label: "3" },
  { value: "4", label: "+4" },
];
---

<aside class="property-filters w-full lg:w-72 lg:shrink-0" data-property-filters>
  <div class="space-y-4 lg:sticky lg:top-6">

    <div class="rounded-xl border border-border bg-surface-raised p-5">
      <p class="text-[10px] uppercase tracking-widest font-semibold text-secondary mb-3">Reference Nº / Name</p>
      <div class="relative">
        <input
          type="search" data-filter="name" placeholder="Search"
          class="w-full rounded-md border border-border bg-surface px-3 py-2 pr-9 text-sm text-secondary placeholder:text-faint focus:outline-none focus:ring-2 focus:ring-primary-600"
        />
        <i class="fa-solid fa-magnifying-glass text-faint text-sm absolute right-3 top-1/2 -translate-y-1/2 pointer-events-none" aria-hidden="true"></i>
      </div>
    </div>

    <div class="rounded-xl border border-border bg-surface-raised p-5">
      <p class="text-[10px] uppercase tracking-widest font-semibold text-secondary mb-3">Price per night</p>
      <div class="flex items-center gap-2">
        <input
          type="number" data-filter="min-price"
          min={minPrice} max={maxPrice} value={minPrice}
          class="w-full rounded-md border border-border bg-surface px-3 py-2 text-sm text-secondary focus:outline-none focus:ring-2 focus:ring-primary-600"
        />
        <span class="text-faint">—</span>
        <input
          type="number" data-filter="max-price"
          min={minPrice} max={maxPrice} value={maxPrice}
          class="w-full rounded-md border border-border bg-surface px-3 py-2 text-sm text-secondary focus:outline-none focus:ring-2 focus:ring-primary-600"
        />
      </div>
      <div class="mt-3">
        <div class="relative h-1 rounded-full bg-surface-alt">
          <div data-price-track class="absolute h-1 rounded-full bg-primary-600" style="left: 0%; right: 0%;"></div>
        </div>
        <div class="mt-2 flex justify-between text-xs text-faint">
          <span>{currencySymbol}{minPrice}</span>
          <span>{currencySymbol}{maxPrice}+</span>
        </div>
      </div>
    </div>

    {types.length > 0 && (
      <div class="rounded-xl border border-border bg-surface-raised p-5">
        <p class="text-[10px] uppercase tracking-widest font-semibold text-secondary mb-3">Type of accommodation</p>
        <div class="space-y-2">
          {types.map((t) => (
            <label class="flex items-center gap-3 cursor-pointer group">
              <input
                type="checkbox" data-filter="type" value={t.value}
                class="size-4 rounded border-border text-primary-600 focus:ring-primary-600"
              />
              <span class="flex-1 text-sm text-secondary group-hover:text-primary-600">{t.label}</span>
              <span class="text-xs text-faint">({t.count})</span>
            </label>
          ))}
        </div>
      </div>
    )}

    <div class="rounded-xl border border-border bg-surface-raised p-5">
      <p class="text-[10px] uppercase tracking-widest font-semibold text-secondary mb-3">Bathrooms and toilets</p>
      <div class="flex gap-2" role="group" data-filter-group="bathrooms">
        {BATHROOM_OPTIONS.map((opt, i) => (
          <button
            type="button"
            data-filter="bathrooms"
            data-value={opt.value}
            aria-pressed={i === 0 ? "true" : "false"}
            class:list={[
              "flex-1 rounded-md px-2 py-2 text-sm font-semibold transition",
              i === 0
                ? "bg-secondary text-white"
                : "bg-surface text-secondary border border-border hover:border-border-hover",
            ]}
          >
            {opt.label}
          </button>
        ))}
      </div>
    </div>

    {categories.length > 0 && (
      <div class="rounded-xl border border-border bg-surface-raised p-5">
        <p class="text-[10px] uppercase tracking-widest font-semibold text-secondary mb-3">Category</p>
        <div class="space-y-2">
          {categories.map((c) => (
            <label class="flex items-start gap-3 cursor-pointer group">
              <input
                type="checkbox" data-filter="category" value={c.value}
                class="mt-0.5 size-4 rounded border-border text-primary-600 focus:ring-primary-600"
              />
              <span class="flex-1 text-sm text-secondary group-hover:text-primary-600 leading-snug">{c.label}</span>
              <span class="text-xs text-faint shrink-0">({c.count})</span>
            </label>
          ))}
        </div>
      </div>
    )}

    {features.length > 0 && (
      <div class="rounded-xl border border-border bg-surface-raised p-5">
        <p class="text-[10px] uppercase tracking-widest font-semibold text-secondary mb-3">Main features</p>
        <div class="space-y-2">
          {features.map((f) => (
            <label class="flex items-center gap-3 cursor-pointer group">
              <input
                type="checkbox" data-filter="amenity" value={f.value}
                class="size-4 rounded border-border text-primary-600 focus:ring-primary-600"
              />
              <span class="flex-1 text-sm text-secondary group-hover:text-primary-600">{f.label}</span>
              <span class="text-xs text-faint">({f.count})</span>
            </label>
          ))}
        </div>
      </div>
    )}

    <div class="px-2">
      <button
        type="button" data-filter-reset
        class="text-sm text-primary-600 hover:underline font-semibold"
      >
        Reset all filters
      </button>
    </div>
  </div>
</aside>
