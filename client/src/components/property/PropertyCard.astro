---
import StrapiImage from "../StrapiImage.astro";
import { currencySymbol } from "../../utils/property/currency";
import { slugify } from "../../utils/property/filter-options";

interface Amenity { name: string; icon?: string | null }
interface Address { city?: string | null; state?: string | null; country?: string | null }
interface Pricing { basePrice: number; currency: string }
interface Image { url: string; alternativeText?: string | null }

interface Props {
  href: string;
  title: string;
  propertyType?: string | null;
  bedrooms?: number | null;
  bathrooms?: number | null;
  accommodates?: number | null;
  address?: Address | null;
  pricing?: Pricing | null;
  amenities?: Amenity[] | null;
  images?: Image[] | null;
  tags?: string[] | null;
  /** Optional — Guesty listings API does not currently expose ratings */
  rating?: { value: number; count: number } | null;
}

const {
  href, title, propertyType, bedrooms, bathrooms, accommodates,
  address, pricing, amenities, images, tags, rating,
} = Astro.props;

const hero = images && images.length > 0 ? images[0] : null;
const imageCount = (images ?? []).length;
const priceLabel = pricing ? `${currencySymbol(pricing.currency)}${Math.round(pricing.basePrice)}` : null;
const subtitle = [address?.city, propertyType].filter(Boolean).join(" — ");

const amenityKey = (amenities ?? []).map((a) => slugify(a.name)).join(" ");
const tagKey = (tags ?? []).join(" ");
---

<a
  href={href}
  class="property-card group flex flex-col rounded-xl border border-border bg-surface-raised overflow-hidden transition hover:shadow-lg hover:border-border-hover"
  data-property-card
  data-price={pricing?.basePrice ?? 0}
  data-bedrooms={bedrooms ?? 0}
  data-bathrooms={bathrooms ?? 0}
  data-guests={accommodates ?? 0}
  data-property-type={propertyType ?? ""}
  data-amenities={amenityKey}
  data-tags={tagKey}
  data-city={address?.city ?? ""}
  data-title={title.toLowerCase()}
>
  <div class="relative overflow-hidden aspect-[4/3]">
    {hero ? (
      <StrapiImage
        class="absolute inset-0 w-full h-full object-cover transition duration-500 group-hover:scale-[1.03]"
        src={hero.url}
        alt={hero.alternativeText || title}
        height={600}
        width={800}
      />
    ) : (
      <div class="absolute inset-0 bg-surface-alt flex items-center justify-center">
        <i class="fa-solid fa-camera fa-2x text-faint" aria-hidden="true"></i>
      </div>
    )}

    {rating && (
      <span class="absolute top-3 left-3 inline-flex items-center gap-1 rounded-full bg-surface-raised/95 px-2.5 py-1 text-xs font-semibold text-secondary shadow-sm backdrop-blur">
        <i class="fa-solid fa-star text-amber-500 text-[10px]" aria-hidden="true"></i>
        {rating.value.toFixed(1)} <span class="text-faint font-normal">({rating.count})</span>
      </span>
    )}

    {imageCount > 1 && (
      <div class="absolute bottom-3 left-1/2 -translate-x-1/2 flex gap-1.5">
        {Array.from({ length: Math.min(imageCount, 5) }).map((_, i) => (
          <span class={`block w-1.5 h-1.5 rounded-full ${i === 0 ? "bg-white" : "bg-white/50"}`}></span>
        ))}
      </div>
    )}
  </div>

  <div class="flex flex-col flex-1 p-5">
    <h2 class="text-base font-semibold text-secondary group-hover:text-primary-600 transition font-heading leading-snug line-clamp-2 min-h-[2.75rem]">
      {title}
    </h2>

    {subtitle && (
      <p class="mt-1 flex items-center gap-1.5 text-sm text-muted">
        <i class="fa-solid fa-location-dot text-primary-600 text-xs" aria-hidden="true"></i>
        {subtitle}
      </p>
    )}

    <div class="mt-4 flex flex-wrap items-center gap-x-4 gap-y-2 text-xs text-muted">
      {bedrooms != null && (
        <span class="inline-flex items-center gap-1.5">
          <i class="fa-solid fa-bed text-secondary" aria-hidden="true"></i>
          <span><strong class="text-secondary font-semibold">{bedrooms}</strong> {bedrooms === 1 ? "Bed" : "Beds"}</span>
        </span>
      )}
      {accommodates != null && (
        <span class="inline-flex items-center gap-1.5">
          <i class="fa-solid fa-user-group text-secondary" aria-hidden="true"></i>
          <span><strong class="text-secondary font-semibold">{accommodates}</strong> Guests</span>
        </span>
      )}
      {bathrooms != null && (
        <span class="inline-flex items-center gap-1.5">
          <i class="fa-solid fa-bath text-secondary" aria-hidden="true"></i>
          <span><strong class="text-secondary font-semibold">{bathrooms}</strong> {bathrooms === 1 ? "Bath" : "Baths"}</span>
        </span>
      )}
    </div>

    {priceLabel && (
      <div class="mt-4 pt-4 border-t border-border">
        <p class="text-xs text-faint">From</p>
        <p class="text-lg font-bold text-secondary">
          {priceLabel}
          <span class="ml-0.5 text-sm font-normal text-muted">/ night</span>
        </p>
      </div>
    )}
  </div>
</a>
