---
interface Props {
  cities: string[];
  types: string[];
  maxGuests: number;
}

const { cities, types, maxGuests } = Astro.props;
---

<section class="property-search bg-surface" data-property-search>
  <div class="container py-4">
    <div class="flex items-stretch rounded-full border border-border bg-surface-raised shadow-sm overflow-hidden">

      <label class="flex-1 px-5 py-3 hover:bg-surface-alt transition cursor-pointer">
        <span class="block text-[10px] uppercase tracking-widest font-semibold text-secondary">Town</span>
        <select
          data-search="city"
          class="mt-0.5 w-full bg-transparent text-sm text-muted focus:outline-none cursor-pointer"
        >
          <option value="">Any town</option>
          {cities.map((c) => <option value={c}>{c}</option>)}
        </select>
      </label>

      <span class="self-stretch w-px bg-border" aria-hidden="true"></span>

      <label class="flex-1 px-5 py-3 hover:bg-surface-alt transition cursor-pointer">
        <span class="block text-[10px] uppercase tracking-widest font-semibold text-secondary">When</span>
        <div class="mt-0.5 flex items-center gap-1 text-sm text-muted">
          <input type="date" data-search="check-in" aria-label="Check in"
            class="w-full bg-transparent focus:outline-none cursor-pointer" />
          <span>—</span>
          <input type="date" data-search="check-out" aria-label="Check out"
            class="w-full bg-transparent focus:outline-none cursor-pointer" />
        </div>
      </label>

      <span class="self-stretch w-px bg-border" aria-hidden="true"></span>

      <label class="flex-1 px-5 py-3 hover:bg-surface-alt transition cursor-pointer">
        <span class="block text-[10px] uppercase tracking-widest font-semibold text-secondary">Accommodation</span>
        <select
          data-search="type"
          class="mt-0.5 w-full bg-transparent text-sm text-muted focus:outline-none cursor-pointer"
        >
          <option value="">Any type</option>
          {types.map((t) => <option value={t}>{t}</option>)}
        </select>
      </label>

      <span class="self-stretch w-px bg-border" aria-hidden="true"></span>

      <label class="flex-1 px-5 py-3 hover:bg-surface-alt transition cursor-pointer">
        <span class="block text-[10px] uppercase tracking-widest font-semibold text-secondary">Guests</span>
        <input
          type="number" min="1" max={Math.max(maxGuests, 16)}
          placeholder="Any" data-search="guests"
          class="mt-0.5 w-full bg-transparent text-sm text-muted focus:outline-none placeholder:text-faint"
        />
      </label>

      <button
        type="button"
        data-search-trigger
        aria-label="Search"
        class="m-2 inline-flex items-center justify-center w-12 h-12 shrink-0 rounded-full bg-primary-600 text-white hover:bg-primary-700 transition shadow"
      >
        <i class="fa-solid fa-magnifying-glass" aria-hidden="true"></i>
      </button>
    </div>
  </div>
</section>
