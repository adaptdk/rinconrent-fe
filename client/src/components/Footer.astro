---
import type { GlobalPageFooter, SocialLink } from "../utils/types";
import StrapiImage from "./StrapiImage.astro";

interface Props {
  footer: GlobalPageFooter;
  contactPhone?: string | null;
  contactEmail?: string | null;
  contactAddress?: string | null;
  socialLinks?: SocialLink[];
}

const { footer, contactPhone, contactEmail, contactAddress, socialLinks } =
  Astro.props;
const { logo, footerMenus, text } = footer;

const socialFaMap: Record<string, string> = {
  LINKEDIN:  "fa-brands fa-linkedin-in",
  FACEBOOK:  "fa-brands fa-facebook-f",
  INSTAGRAM: "fa-brands fa-instagram",
  TWITTER:   "fa-brands fa-x-twitter",
  YOUTUBE:   "fa-brands fa-youtube",
  TIKTOK:    "fa-brands fa-tiktok",
};
---

<footer class="bg-dark-blue text-sand-white">
  <div class="container py-16">
    <div class="grid grid-cols-1 gap-12 lg:grid-cols-[1fr_2fr]">
      <!-- Left: logo + contact -->
      <div class="flex flex-col gap-8">
        {
          logo?.image && (
            <a
              href={logo.logoLink || "/"}
              aria-label={logo.logoText || "Home"}
              class="block"
            >
              <StrapiImage
                src={logo.image.url}
                alt={logo.image.alternativeText || logo.logoText || "Logo"}
                width={180}
                height={56}
                class="h-auto w-auto max-w-[180px]"
              />
            </a>
          )
        }

        <address class="not-italic flex flex-col gap-3 text-body-s">
          {
            contactPhone && (
              <a
                href={`tel:${contactPhone}`}
                class="flex items-start gap-2.5 text-sand-white/75 transition-colors duration-200 hover:text-sand-white"
              >
                <i class="fa-solid fa-phone mt-0.5 shrink-0" aria-hidden="true"></i>
                <span class="font-semibold">{contactPhone}</span>
              </a>
            )
          }
          {
            contactEmail && (
              <a
                href={`mailto:${contactEmail}`}
                class="flex items-start gap-2.5 text-sand-white/75 transition-colors duration-200 hover:text-sand-white"
              >
                <i class="fa-solid fa-envelope mt-0.5 shrink-0" aria-hidden="true"></i>
                <span>{contactEmail}</span>
              </a>
            )
          }
          {
            contactAddress && (
              <p class="flex items-start gap-2.5 text-sand-white/75">
                <i class="fa-solid fa-location-dot mt-0.5 shrink-0" aria-hidden="true"></i>
                <span>{contactAddress}</span>
              </p>
            )
          }
        </address>
      </div>

      <!-- Right: navigation menu columns -->
      {
        footerMenus && footerMenus.length > 0 && (
          <div class="grid grid-cols-1 gap-8 sm:grid-cols-3">
            {footerMenus.map((menu) => (
              <nav aria-label={menu.title}>
                <p class="mb-4 text-body-xs font-semibold uppercase tracking-widest text-orange-alt">
                  {menu.title}
                </p>
                <ul class="flex flex-col gap-2">
                  {menu.links?.map((link) => (
                    <li>
                      <a
                        href={link.href}
                        class="text-body-s text-sand-white/70 transition-colors duration-200 hover:text-sand-white"
                        target={link.isExternal ? "_blank" : "_self"}
                        rel={
                          link.isExternal ? "noopener noreferrer" : undefined
                        }
                      >
                        {link.label}
                      </a>
                    </li>
                  ))}
                </ul>
              </nav>
            ))}
          </div>
        )
      }
    </div>
  </div>

  <!-- Bottom bar -->
  <div class="border-t border-white/10">
    <div
      class="container py-6 flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between"
    >
      {text && <p class="text-body-xs text-sand-white/50">{text}</p>}

      {
        socialLinks && socialLinks.length > 0 && (
          <ul class="flex items-center gap-4">
            {socialLinks.map((item) => {
              const iconClass = socialFaMap[item.platform];
              if (!iconClass) return null;
              return (
                <li>
                  <a
                    href={item.href}
                    aria-label={item.label || item.platform}
                    class="block text-sand-white/50 transition-colors duration-200 hover:text-sand-white"
                    target="_blank"
                    rel="noopener noreferrer"
                  >
                    <i class={`${iconClass} fa-lg`} aria-hidden="true"></i>
                  </a>
                </li>
              );
            })}
          </ul>
        )
      }
    </div>
  </div>
</footer>
