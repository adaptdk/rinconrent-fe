---
import type { Link } from "../utils/types";

interface Props {
  data: {
    isVisible: boolean;
    link: Link;
    description: string;
  };
}

const {
  data: {
    isVisible,
    description,
    link,
  },
} = Astro.props as Props;

if (!isVisible) return null;
---

<div
  id="banner"
  class="flex items-center justify-center gap-x-4 bg-primary-900 px-6 py-2 text-sm text-white/90"
>
  <p>
    <a href={link.href} target={link?.isExternal ? "_blank" : "_self"} class="inline-flex items-center gap-2 hover:text-white transition">
      <strong class="font-semibold">{link.label}</strong>
      <span class="text-white/60">&mdash;</span>
      <span>{description}</span>
      <i class="fa-solid fa-arrow-right fa-xs" aria-hidden="true"></i>
    </a>
  </p>
  <button
    id="dismiss-button"
    type="button"
    class="rounded p-1 text-white/60 hover:text-white transition"
    aria-label="Dismiss"
  >
    <i class="fa-solid fa-xmark" aria-hidden="true"></i>
  </button>
</div>

<script>
  const dismissButton = document.getElementById("dismiss-button");
  const banner = document.getElementById("banner");

  if (dismissButton && banner) {
    dismissButton.addEventListener("click", function () {
      banner.style.display = "none";
    });
  }
</script>
