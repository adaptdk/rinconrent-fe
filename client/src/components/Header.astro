---
import type { GlobalPageHeader, NavItem } from "../utils/types";
import StrapiImage from "./StrapiImage.astro";
import NavItem from "./NavItem.astro";
import Topbar from "./Topbar.astro";

interface Props {
  data: GlobalPageHeader;
}

const { data: { logo, topNav, navItems, ctaGroup } } = Astro.props;
const currentPath = Astro.url.pathname;

const allItems: import("../utils/types").NavItem[] = [
  ...navItems,
  ...(ctaGroup ? [ctaGroup] : []),
];
const itemsWithChildren = allItems.filter(i => i.children && i.children.length > 0);

function submenuId(label: string) {
  return label.toLowerCase().replace(/[^a-z0-9]+/g, "-");
}
---

<Topbar topNav={topNav ?? []} />

<header class="sticky top-0 z-[998] bg-sand-white border-b border-grey-border shadow-md">
  <div class="container flex items-center justify-between py-3 lg:py-5">

    <!-- Logo -->
    <a href={logo.logoLink} aria-label={logo.logoText || "Home"} class="block w-[110px] lg:w-[150px] shrink-0">
      <StrapiImage
        src={logo.image.url}
        alt={logo.image.alternativeText || logo.logoText}
        width={150}
        height={40}
        class="w-full h-auto"
      />
    </a>

    <!-- Desktop nav -->
    <nav class="hidden lg:flex items-center gap-2 xl:gap-4" aria-label="Main navigation">
      {navItems.map(item => (
        <NavItem item={item} currentPath={currentPath} />
      ))}
    </nav>

    <!-- Desktop CTA group -->
    {ctaGroup && (
      <div class="hidden lg:block">
        <NavItem item={ctaGroup} currentPath={currentPath} isBold />
      </div>
    )}

    <!-- Mobile hamburger -->
    <button
      id="mobile-toggle"
      class="lg:hidden p-2 -mr-2 text-dark-grey hover:text-dark-blue transition-colors duration-200"
      aria-label="Open navigation menu"
      aria-expanded="false"
      aria-controls="mobile-menu"
    >
      <i id="icon-open" class="fa-solid fa-bars fa-xl" aria-hidden="true"></i>
      <i id="icon-close" class="hidden fa-solid fa-xmark fa-xl" aria-hidden="true"></i>
    </button>
  </div>

  <!-- Mobile main menu -->
  <div
    id="mobile-menu"
    class="hidden lg:hidden border-t border-grey-border bg-sand-white px-4 pb-6"
    aria-label="Mobile navigation"
  >
    <nav class="mt-1">
      {navItems.map(item => (
        <NavItem item={item} currentPath={currentPath} mobileMode />
      ))}
      {ctaGroup && (
        <NavItem item={ctaGroup} currentPath={currentPath} isBold mobileMode />
      )}
    </nav>

    {(topNav ?? []).length > 0 && (
      <ul class="mt-5 pt-4 border-t border-grey-border space-y-1">
        {topNav.map(link => (
          <li>
            <a
              href={link.href}
              class="block py-1 text-body-s text-grey-disabled hover:text-dark-blue transition-colors duration-200"
              target={link.isExternal ? "_blank" : "_self"}
              rel={link.isExternal ? "noopener noreferrer" : undefined}
            >
              {link.label}
            </a>
          </li>
        ))}
      </ul>
    )}
  </div>

  <!-- Mobile submenu overlays (slide in from right) -->
  {itemsWithChildren.map(item => (
    <div
      id={`submenu-${submenuId(item.label)}`}
      class="header__mobile-overlay"
      aria-hidden="true"
      aria-label={`${item.label} submenu`}
    >
      <!-- Back button header -->
      <div class="flex items-center border-b border-grey-border px-4 py-3">
        <button
          class="flex items-center gap-2 font-semibold text-dark-grey hover:text-dark-blue transition-colors duration-200"
          data-submenu-close
          aria-label={`Back to main menu`}
        >
          <i class="fa-solid fa-chevron-down fa-lg inline-block rotate-90 shrink-0" aria-hidden="true"></i>
          {item.label}
        </button>
      </div>

      <!-- Submenu links -->
      <ul class="px-4 py-2">
        {item.children!.map(child => (
          <li class="border-b border-grey-border last:border-0">
            <a
              href={child.href}
              class="block py-3 text-dark-grey hover:text-dark-blue transition-colors duration-200"
              target={child.isExternal ? "_blank" : "_self"}
              rel={child.isExternal ? "noopener noreferrer" : undefined}
            >
              {child.label}
            </a>
          </li>
        ))}
      </ul>
    </div>
  ))}
</header>

<script>
  import "../scripts/header";
</script>
