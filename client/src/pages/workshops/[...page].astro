---
import StrapiImage from "../../components/StrapiImage.astro";
import BaseLayout from "../../layouts/BaseLayout.astro";
import Pagination from "../../components/Pagination.astro";
import { getCollection } from "astro:content";

import type { CollectionEntry } from "astro:content";

type Item = CollectionEntry<"strapiWorkshops">;

type CollectionItem = {
  params: { slug: string };
  props: Item;
};

type PaginatedPage = {
  data: CollectionItem[];
  currentPage: number;
  total: number;
  size: number;
  url: {
    prev: string | null;
    next: string | null;
  };
};

const levelConfig: Record<string, { label: string; color: string }> = {
  beginner: { label: "Beginner", color: "bg-green-100 text-green-700" },
  intermediate: { label: "Intermediate", color: "bg-amber-100 text-amber-700" },
  advanced: { label: "Advanced", color: "bg-red-100 text-red-700" },
};

function formatPrice(price: number | null | undefined) {
  if (price === null || price === undefined) return null;
  if (price === 0) return "Free";
  return `$${price.toFixed(2)}`;
}

function formatDate(dateStr: string | null | undefined) {
  if (!dateStr) return null;
  return new Date(dateStr).toLocaleDateString("en-US", { month: "short", day: "numeric", year: "numeric" });
}

export async function getStaticPaths({ paginate }: { paginate: any }) {
  const collection = await getCollection("strapiWorkshops");

  function createStaticPaths(items: Item[]) {
    return items.map((item) => ({
      params: { slug: item.data.slug },
      props: item,
    }));
  }

  const staticPaths = createStaticPaths(collection);

  const paginatedData = paginate(staticPaths, {
    pageSize: 12,
    url: { prev: "/workshops", next: "/workshops" },
  });

  return paginatedData;
}

const { page }: { page: PaginatedPage } = Astro.props;
const items = page.data;
const currentPage = page.currentPage;
const totalPages = Math.ceil(page.total / page.size);
---

<BaseLayout>
  <section class="container py-16">
    <div class="text-center max-w-2xl mx-auto">
      <h1 class="text-4xl font-bold tracking-tight text-secondary font-heading">Workshops</h1>
      <p class="mt-4 text-lg text-muted leading-relaxed">
        Hands-on courses taught by industry practitioners. Pick your level and start building.
      </p>
    </div>

    {items.length === 0 && (
      <p class="mt-10 text-center text-muted">No workshops scheduled yet. Check back soon.</p>
    )}

    <div class="mt-14 grid gap-8 sm:grid-cols-2 lg:grid-cols-3">
      {items.map((item: CollectionItem) => {
        const { title, description, coverImage, skillLevel, instructor, duration, date, price } = item.props.data;
        const level = skillLevel ? levelConfig[skillLevel] : null;
        const priceLabel = formatPrice(price);
        const dateLabel = formatDate(date);

        return (
          <a
            href={`/workshops/${item.params.slug}`}
            class="group flex flex-col rounded-xl border border-border bg-surface-raised overflow-hidden transition hover:shadow-lg hover:border-border-hover"
          >
            <div class="relative overflow-hidden">
              {coverImage ? (
                <StrapiImage
                  class="aspect-[16/10] w-full object-cover transition duration-500 group-hover:scale-[1.03]"
                  src={coverImage.url}
                  alt={coverImage.alternativeText || ""}
                  height={300}
                  width={480}
                />
              ) : (
                <div class="aspect-[16/10] w-full bg-surface-alt" />
              )}
              {level && (
                <span class={`absolute top-3 left-3 rounded-full px-3 py-1 text-xs font-semibold ${level.color}`}>
                  {level.label}
                </span>
              )}
            </div>
            <div class="flex flex-col flex-1 p-6">
              <h2 class="text-lg font-semibold text-secondary group-hover:text-primary-600 transition font-heading leading-snug">
                {title}
              </h2>
              {instructor && <p class="mt-1 text-sm text-primary-600">by {instructor}</p>}
              <p class="mt-3 text-sm text-muted leading-relaxed line-clamp-2 flex-1">{description}</p>
              <div class="mt-4 flex flex-wrap items-center gap-x-4 gap-y-2 text-xs text-faint border-t border-border pt-4">
                {dateLabel && (
                  <span class="flex items-center gap-1">
                    <i class="fa-solid fa-calendar fa-xs shrink-0" aria-hidden="true"></i>
                    {dateLabel}
                  </span>
                )}
                {duration && (
                  <span class="flex items-center gap-1">
                    <i class="fa-solid fa-clock fa-xs shrink-0" aria-hidden="true"></i>
                    {duration}
                  </span>
                )}
                {priceLabel && (
                  <span class={`ml-auto font-semibold text-sm ${price === 0 ? 'text-green-700' : 'text-secondary'}`}>{priceLabel}</span>
                )}
              </div>
            </div>
          </a>
        );
      })}
    </div>

    {totalPages > 1 && (
      <div class="mt-12">
        <Pagination
          previousPage={page.url.prev ? page.url.prev : null}
          nextPage={page.url.next ? page.url.next : null}
          currentPage={currentPage}
          totalPages={totalPages}
        />
      </div>
    )}
  </section>
</BaseLayout>
