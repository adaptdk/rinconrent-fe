---
import BaseLayout from "../layouts/BaseLayout.astro";
import BlockRenderer from "../components/blocks/BlockRenderer.astro";
import PageHeader from "../components/PageHeader.astro";
import type { PageHeaderProps } from "../utils/types";

import { getLandingPageData } from "../utils/loaders";

const data = await getLandingPageData();

const landingPage = data?.data;

if (!landingPage) throw new Error("Landing page not found");
---

<BaseLayout>
  <PageHeader data={landingPage.pageHeader as PageHeaderProps | null} fallbackTitle={landingPage.title} />
  <BlockRenderer blocks={landingPage.blocks} />
</BaseLayout>

