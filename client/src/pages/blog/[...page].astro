---
import { formatDate } from "../../utils/index";
import StrapiImage from "../../components/StrapiImage.astro";
import BaseLayout from "../../layouts/BaseLayout.astro";
import Pagination from "../../components/Pagination.astro";
import { getCollection } from "astro:content";

import type { CollectionEntry } from "astro:content";

type Post = CollectionEntry<"strapiPosts">;

type CollectionArticle = {
  params: { slug: string };
  props: Post;
};

type PaginatedPage = {
  data: CollectionArticle[];
  currentPage: number;
  total: number;
  size: number;
  url: {
    prev: string | null;
    next: string | null;
  };
};

export async function getStaticPaths({ paginate }: { paginate: any }) {
  const collection = await getCollection("strapiPosts");

  function createStaticPaths(articles: Post[]) {
    return articles.map((article) => ({
      params: { slug: article.data.slug },
      props: article,
    }));
  }

  const staticPaths = createStaticPaths(collection);

  const paginatedData = paginate(staticPaths, {
    pageSize: 5,
    url: {
      prev: "/blog",
      next: "/blog",
    },
  });

  return paginatedData;
}

const { page }: { page: PaginatedPage } = Astro.props;

const articles = page.data;
const currentPage = page.currentPage;
const totalPages = Math.ceil(page.total / page.size);
---

<BaseLayout>
  <section class="container py-16">
    <h1 class="text-4xl font-bold tracking-tight text-secondary font-heading">Blog</h1>

    {articles.length === 0 && (
      <p class="mt-10 text-muted">No articles published yet. Check back soon.</p>
    )}

    {/* Featured post */}
    {articles.length > 0 && (
      <a href={`/blog/${articles[0].params.slug}`} class="group mt-12 block">
        <div class="overflow-hidden rounded-2xl">
          <StrapiImage
            class="aspect-[2/1] w-full object-cover transition duration-500 group-hover:scale-[1.02]"
            src={articles[0].props.data.featuredImage.url}
            alt={articles[0].props.data.featuredImage.alternativeText || ""}
            height={600}
            width={1200}
          />
        </div>
        <div class="mt-5">
          <time class="text-sm text-faint">{formatDate(articles[0].props.data.publishedAt)}</time>
          <h2 class="mt-1 text-2xl font-bold text-secondary group-hover:text-primary-600 transition font-heading">
            {articles[0].props.data.title}
          </h2>
          <p class="mt-2 max-w-2xl text-muted leading-relaxed">
            {articles[0].props.data.description}
          </p>
        </div>
      </a>
    )}

    {/* Post list */}
    {articles.length > 1 && (
      <div class="mt-14 border-t border-border pt-10 space-y-0 divide-y divide-border">
        {articles.slice(1).map((article: CollectionArticle) => (
          <a href={`/blog/${article.params.slug}`} class="group flex gap-6 py-6 items-center">
            <div class="w-24 h-24 shrink-0 overflow-hidden rounded-xl">
              <StrapiImage
                class="h-full w-full object-cover"
                src={article.props.data.featuredImage.url}
                alt={article.props.data.featuredImage.alternativeText || ""}
                height={200}
                width={200}
              />
            </div>
            <div>
              <time class="text-xs text-faint">{formatDate(article.props.data.publishedAt)}</time>
              <h3 class="mt-0.5 font-semibold text-secondary group-hover:text-primary-600 transition font-heading leading-snug">
                {article.props.data.title}
              </h3>
            </div>
          </a>
        ))}
      </div>
    )}

    {totalPages > 1 && (
      <div class="mt-12">
        <Pagination
          previousPage={page.url.prev ? page.url.prev : null}
          nextPage={page.url.next ? page.url.next : null}
          currentPage={currentPage}
          totalPages={totalPages}
        />
      </div>
    )}
  </section>
</BaseLayout>
