---
import BaseLayout from "../../layouts/BaseLayout.astro";
import BlockRenderer from "../../components/blocks/BlockRenderer.astro";
import PageHeader from "../../components/PageHeader.astro";
import { getCollection } from "astro:content";
import { getPageHeader } from "../../utils/loaders";

import type { CollectionEntry } from "astro:content";

type Page = CollectionEntry<"strapiPages">;

export async function getStaticPaths() {
  const collection = await getCollection("strapiPages");

  function createStaticPaths(articles: Page[]) {
    return articles.map(article => ({
      params: { slug: article.data.slug },
      props: article.data
    }));
  }

  return createStaticPaths(collection);
}


const { props } = Astro;
const { title, blocks } = props;
const { slug } = Astro.params;

const pageHeader = await getPageHeader(slug);
---

<BaseLayout>
  <PageHeader data={pageHeader} fallbackTitle={title} />
  <BlockRenderer blocks={blocks || []} />
</BaseLayout>
